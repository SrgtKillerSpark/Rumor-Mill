#!/usr/bin/env bash
# SPA-1637: Divergence guardrail — abort push if local main and origin/main
# have diverged by more than 5 commits in either direction.

MAX_DIVERGE=5

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_ref" == "refs/heads/main" ]]; then
    git fetch origin main --quiet 2>/dev/null

    ahead=$(git rev-list --count origin/main..main 2>/dev/null || echo 0)
    behind=$(git rev-list --count main..origin/main 2>/dev/null || echo 0)

    if (( behind > MAX_DIVERGE )); then
      echo "ERROR: local main is $behind commits behind origin/main (max $MAX_DIVERGE)."
      echo "Run 'git pull --rebase origin main' or 'git merge origin/main' before pushing."
      exit 1
    fi

    if (( ahead > MAX_DIVERGE )); then
      echo "WARNING: local main is $ahead commits ahead of origin/main."
      echo "Consider pushing more frequently to avoid large divergences."
    fi
  fi
done

exit 0
